# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tauri / Rust build output (also covered by src-tauri/.gitignore,
# kept here for editors/tools that scan from the repo root)
src-tauri/target/
src-tauri/gen/

# Env files (never commit secrets / local overrides)
.env
.env.*
!.env.example

# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# Editors
.vscode/*
!.vscode/extensions.json
.idea/
*.swp

# Internal project notes (not for public repo)
CLAUDE.md
